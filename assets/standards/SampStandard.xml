  <content>
    <subject>Virtual observatory</subject>
    <!-- you can give further keywords, one per subject element;
    use the IVOA thesaurus if possible:
    http://www.ivoa.net/rdf/Vocabularies/vocabularies-20091007/IVOAT/IVOAT.html
